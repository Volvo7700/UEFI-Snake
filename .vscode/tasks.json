{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "uefi_build",
      "type": "shell",
      "command": "cmd.exe",
      "args": [
        "/c",
        "call edksetup.bat && build -p UEFI-Snake/UEFI-Snake.dsc -a X64 -t CLANGPDB"
      ],
      "options": {
        "cwd": "C:/EDK/EDK2"
      }
    },
    {
      "label": "copy_efi",
      "type": "shell",
      "dependsOn": "uefi_build",
      "command": "powershell",
      "args": [
        "-Command",
        "New-Item -ItemType Directory -Force ESP/EFI/BOOT | Out-Null; Copy-Item C:/EDK/Build/UEFI-Snake/DEBUG_CLANGPDB/X64/Start.efi ESP/EFI/BOOT/BOOTX64.EFI -Force"
      ]
    },
    {
      "label": "run_qemu",
      "type": "shell",
      "dependsOn": "copy_efi",
      "command": "cmd.exe",
      "args": [
        "/c",
        "call run-qemu.bat"
      ],
      "options": {
        "cwd": "C:/EDK/UEFI-Snake"
      }
    },
    {
      "label": "uefi_all",
      "dependsOrder": "sequence",
      "dependsOn": [
        "uefi_build",
        "copy_efi",
        "run_qemu"
      ],
      "problemMatcher": []
    }
  ]
}